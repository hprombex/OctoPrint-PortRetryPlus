<form id="settings_plugin_portretryplus" class="form-horizontal">
    <h4>PortRetryPlus settings</h4>
    <div class="control-group">
        <label class="control-label">Interval</label>
        <div class="controls" data-toggle="tooltip" title="The interval with which to retry connecting the printer.">
            <div class="input-append">
                <input type="number" step="1" min="0.1" class="input-mini text-right" data-bind="value: settings.plugins.portretryplus.interval">
                <span class="add-on">secs</span>
            </div>
        </div>
    </div>
    <div class="control-group">
        <label class="control-label">Forced serial port:</label>
        <div class="controls">
            <input type="text" class="input" data-bind="value: settings.plugins.portretryplus.forced_port">
            <span class="help-block">Force serial port (eg. /dev/ttyUSB0) if config serial port is AUTO</span>
        </div>
    </div>
</form>
